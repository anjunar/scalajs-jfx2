{
  "name": "@anjunar/scalajs-jfx2",
  "version": "2.0.0",
  "description": "NPM companion package for scalajs-jfx: the default JFX component CSS.",
  "type": "module",
  "license": "MIT",
  "author": "Patrick Bittner",
  "homepage": "https://github.com/anjunar/scalajs-jfx2#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anjunar/scalajs-jfx2.git",
    "directory": "npm/scalajs-jfx2"
  },
  "bugs": {
    "url": "https://github.com/anjunar/scalajs-jfx2/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": [
